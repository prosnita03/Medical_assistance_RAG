# ============================================================
# Medical AI Assistant RAG — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----------------------------------------------------------
# Google Gemini API Key (REQUIRED)
# Get your key at: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------
# App Settings
# ----------------------------------------------------------
APP_NAME="Medical AI Assistant"
APP_VERSION="1.0.0"
DEBUG=false

# ----------------------------------------------------------
# ChromaDB Settings
# ----------------------------------------------------------
CHROMA_PERSIST_DIR=./backend/data/chroma_db
CHROMA_COLLECTION_NAME=medical_knowledge

# ----------------------------------------------------------
# RAG Settings
# ----------------------------------------------------------
# Number of documents to retrieve for each query
TOP_K_RESULTS=5
# Chunk size for document splitting (tokens)
CHUNK_SIZE=800
# Chunk overlap for context continuity
CHUNK_OVERLAP=100

# ----------------------------------------------------------
# LLM Settings
# ----------------------------------------------------------
GEMINI_MODEL=gemini-3.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001
MAX_TOKENS=2048
TEMPERATURE=0.3

# ----------------------------------------------------------
# Server Settings
# ----------------------------------------------------------
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
